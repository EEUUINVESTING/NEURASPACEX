.btn{

position:relative;

overflow:hidden;

background:
linear-gradient(
180deg,
rgba(255,255,255,.35),
rgba(255,255,255,.06)
);

backdrop-filter:
blur(45px)
saturate(220%);

-webkit-backdrop-filter:
blur(45px)
saturate(220%);

border:1px solid
rgba(255,255,255,.30);

border-radius:22px;

box-shadow:

0 20px 60px rgba(0,90,255,.30),

inset 0 1px 1px rgba(255,255,255,.80),

inset 0 -2px 2px rgba(255,255,255,.10);

}
